# bridget-voice-server configuration
# Copy this file to .env and edit the values below.

# ─── Agent Connection (required) ───────────────────────────────────────────
# Which backend to use: openai_compatible, claude_code, codex, custom_command
AGENT_BACKEND=openai_compatible

# For openai_compatible backend:
AGENT_API_URL=http://localhost:11434/v1/chat/completions
AGENT_API_KEY=
AGENT_MODEL=llama3

# For claude_code backend:
# AGENT_BACKEND=claude_code
# CLAUDE_CODE_PATH=claude

# For codex backend:
# AGENT_BACKEND=codex
# CODEX_PATH=codex

# For custom_command backend:
# AGENT_BACKEND=custom_command
# AGENT_COMMAND=python my_agent.py

# ─── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
API_KEY=                         # Key Bridget must send (empty = no auth required)

# ─── Speech-to-Text ───────────────────────────────────────────────────────
STT_PROVIDER=whisper_local       # whisper_local, openai, deepgram
WHISPER_MODEL=base               # tiny, base, small, medium, large (local only)
# STT_API_KEY=                   # Required for openai or deepgram providers

# ─── Text-to-Speech ───────────────────────────────────────────────────────
TTS_PROVIDER=edge_tts            # edge_tts, openai, elevenlabs
TTS_VOICE=en-US-GuyNeural        # Edge-TTS voice name
# TTS_API_KEY=                   # Required for openai or elevenlabs providers
# TTS_OPENAI_VOICE=alloy         # For openai provider: alloy, echo, fable, onyx, nova, shimmer
# TTS_ELEVENLABS_VOICE_ID=       # For elevenlabs provider

# ─── Sessions ─────────────────────────────────────────────────────────────
SESSION_TTL=3600                 # Session expiry in seconds (default: 1 hour)
