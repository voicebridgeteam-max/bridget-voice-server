# bridget-voice-server configuration

# ─── Agent Connection ───────────────────────────────────────────
AGENT_BACKEND=claude_code
CLAUDE_CODE_PATH=claude

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
API_KEY=

# ─── Speech-to-Text ────────────────────────────────────────────
STT_PROVIDER=whisper_local
WHISPER_MODEL=base

# ─── Text-to-Speech ────────────────────────────────────────────
TTS_PROVIDER=edge_tts
TTS_VOICE=en-US-GuyNeural

# ─── Sessions ──────────────────────────────────────────────────
SESSION_TTL=3600
