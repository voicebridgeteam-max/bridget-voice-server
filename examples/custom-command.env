# Custom command backend
# For any agent with a CLI that takes text input and returns text output.
# The command receives the user's message on stdin and should print the response to stdout.

AGENT_BACKEND=custom_command
AGENT_COMMAND=python my_agent.py

HOST=0.0.0.0
PORT=8080
STT_PROVIDER=whisper_local
WHISPER_MODEL=base
TTS_PROVIDER=edge_tts
TTS_VOICE=en-US-GuyNeural
