# Anthropic API (Claude)
# Note: Anthropic's native API is not OpenAI-compatible.
# Use a compatible proxy like LiteLLM, or use the claude_code backend instead.

# Option 1: Via LiteLLM proxy (recommended)
AGENT_BACKEND=openai_compatible
AGENT_API_URL=http://localhost:4000/v1/chat/completions
AGENT_MODEL=anthropic/claude-sonnet-4-20250514
AGENT_API_KEY=sk-your-litellm-key

# Option 2: Via Claude Code CLI (no API key needed, uses OAuth)
# AGENT_BACKEND=claude_code
# CLAUDE_CODE_PATH=claude

HOST=0.0.0.0
PORT=8080
STT_PROVIDER=whisper_local
WHISPER_MODEL=base
TTS_PROVIDER=edge_tts
TTS_VOICE=en-US-GuyNeural
